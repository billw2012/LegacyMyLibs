<effect name = "basic_font_shader">
  <state
    GL_DEPTH_TEST = "false"
    GL_CULL_FACE = "false"
    glDepthMask = "false"
    GL_BLEND = "true"
    glBlendFunc = "GL_ONE, GL_ONE_MINUS_SRC_ALPHA"
  />
  <vert_program>
    <file name = "basic_font_shader_vs.glsl"/>
    <map_param source = "MODELVIEWPROJMAT" target = "uModelViewProj" />
    <map_param source = "pos" target = "uPos" />
  </vert_program>
  <frag_program>
    <file name = "basic_font_shader_fs.glsl"/>
    <map_param source = "texture" target = "uTexture" />
    <map_param source = "color" target = "uColor" />
  </frag_program>
</effect>
